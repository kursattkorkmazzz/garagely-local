{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,

    // For the TypeORM
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "store/root-store",
    "metro.config.js",
    "features/asset/repository/file-system-storage.repository.ts"
  ]
}
